# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
PG_HOST=your-db-host.example.com
PG_PORT=5432
PG_DATABASE=flower_ecosystem
PG_USER=app_user
PG_PASSWORD=

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=generate-a-cryptographically-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_AUTH_MAX=10
