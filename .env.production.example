# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
PG_HOST=your-db-host.example.com
PG_PORT=5432
PG_DATABASE=flower_ecosystem
PG_USER=app_user
PG_PASSWORD=

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=generate-a-cryptographically-random-secret
# MUST be different from JWT_SECRET. Required in production.
JWT_REFRESH_SECRET=generate-a-second-cryptographically-random-secret
JWT_EXPIRES_IN=7d
# Required on first run to seed the admin account. Min 12 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_PASSWORD=generate-a-strong-admin-password
# Optional: separate password for SUPERADMIN. Falls back to ADMIN_PASSWORD if not set.
SUPERADMIN_PASSWORD=generate-a-strong-superadmin-password

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_AUTH_MAX=10
