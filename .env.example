# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=flower_ecosystem
PG_USER=postgres
PG_PASSWORD=changeme

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate secure secrets (use DIFFERENT values for each):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit this file with real values to version control
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme-use-a-different-value

# ─── Admin Accounts ─────────────────────────────────────────────────────────
# Required on first run to seed the ADMIN account. Min 12 characters.
ADMIN_PASSWORD=changeme-min-12-chars
# Optional: separate password for SUPERADMIN. Falls back to ADMIN_PASSWORD if not set.
SUPERADMIN_PASSWORD=changeme-min-12-chars

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcard in production)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20

# ─── Email (SMTP) Configuration ──────────────────────────────────────────────
# Leave blank to log emails to console (development mode)
# Gmail: smtp.gmail.com, port 587, use app password (not your real password)
# Outlook: smtp.office365.com, port 587
# SendGrid: smtp.sendgrid.net, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Flower Ecosystem <noreply@flowerecosystem.com>"

# ─── Cloudinary (Image Uploads) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── AI/ML Services ─────────────────────────────────────────────────────────
# OpenAI API key for AI features (flower scanner, recommendations, etc.)
OPENAI_API_KEY=your_openai_api_key_here
