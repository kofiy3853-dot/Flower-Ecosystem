# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=flower_ecosystem
PG_USER=postgres
PG_PASSWORD=changeme

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit this file with real values to version control
JWT_SECRET=changeme

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcard in production)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20

# ─── AI/ML Services ─────────────────────────────────────────────────────────
# OpenAI API key for AI features (flower scanner, recommendations, etc.)
OPENAI_API_KEY=your_openai_api_key_here
